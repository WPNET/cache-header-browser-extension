{
  "manifest_version": 3,
  "name": "Cache Captain",
  "version": "1.0",
  "description": "Monitor HTTP cache headers (fastcgi-cache, x-cache, cf-cache-status) as a colour-coded badge; clear browser cache in one click.",
  "permissions": [
    "webRequest",
    "webNavigation",
    "tabs",
    "storage",
    "browsingData",
    "notifications"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Cache Captain",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  }
}
